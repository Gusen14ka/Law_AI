{
  "uid": "lex-unified",
  "title": "Lex Analytica - Unified Observability",
  "tags": [
    "lexanalytica",
    "monitoring",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Статус системы",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "up{job=\"lex-backend\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "🔴 АВАРИЯ"
                },
                "1": {
                  "text": "🟢 РАБОТАЕТ"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Заявок за сегодня",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"lex-backend\",path=\"/api/requests\",method=\"POST\"}[24h])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Успешность запросов (%)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "100 * (1 - (((sum(rate(http_requests_total{job=\"lex-backend\",status=~\"5..\"}[5m])) or vector(0)) / clamp_min((sum(rate(http_requests_total{job=\"lex-backend\"}[5m])) or vector(0)), 1))))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 95
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "id": 3
    },
    {
      "type": "stat",
      "title": "Доступность за 30 дней (%)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=\"lex-backend\"}[30d]) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "id": 4
    },
    {
      "type": "gauge",
      "title": "NPS Score",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "lex_nps_score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        }
      },
      "id": 5
    },
    {
      "type": "gauge",
      "title": "CSAT (1-5)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 5,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "lex_csat_score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 1,
          "max": 5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 3
              },
              {
                "color": "yellow",
                "value": 4
              },
              {
                "color": "green",
                "value": 4.5
              }
            ]
          }
        }
      },
      "id": 6
    },
    {
      "type": "gauge",
      "title": "CES (1-7, ниже лучше)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 5,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "lex_ces_score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 1,
          "max": 7,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "yellow",
                "value": 4
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          }
        }
      },
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "RPS",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"lex-backend\"}[1m]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "id": 8
    },
    {
      "type": "timeseries",
      "title": "HTTP статусы",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"lex-backend\",status=~\"2..\"}[1m])) or vector(0)",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"lex-backend\",status=~\"4..\"}[1m])) or vector(0)",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"lex-backend\",status=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "5xx"
        }
      ],
      "id": 9
    },
    {
      "type": "timeseries",
      "title": "Время ответа P50 / P95 / P99",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"lex-backend\"}[5m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"lex-backend\"}[5m])))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"lex-backend\"}[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "id": 10
    },
    {
      "type": "table",
      "title": "Топ эндпоинтов по трафику",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (path, method) (rate(http_requests_total{job=\"lex-backend\"}[5m])))"
        }
      ],
      "id": 11
    },
    {
      "type": "table",
      "title": "Состояние сервисов",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "up{job=\"lex-backend\"}",
          "legendFormat": "Backend"
        },
        {
          "expr": "pg_up",
          "legendFormat": "PostgreSQL"
        },
        {
          "expr": "probe_success{job=\"ollama\"}",
          "legendFormat": "Ollama"
        }
      ],
      "id": 12
    },
    {
      "type": "timeseries",
      "title": "CPU / RAM / Disk",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU"
        },
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM"
        },
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) ) * 100",
          "legendFormat": "Disk"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "id": 13
    },
    {
      "type": "timeseries",
      "title": "Сеть и PostgreSQL",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total[1m]))",
          "legendFormat": "Incoming bytes/s"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total[1m]))",
          "legendFormat": "Outgoing bytes/s"
        },
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "PG connections"
        },
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"lexanalytica\"}[1m])",
          "legendFormat": "Commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"lexanalytica\"}[1m])",
          "legendFormat": "Rollbacks/s"
        }
      ],
      "id": 14
    },
    {
      "type": "stat",
      "title": "PostgreSQL size",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"lexanalytica\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "id": 15
    },
    {
      "type": "stat",
      "title": "AI queue",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 45,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "lex_ai_queue_size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "id": 16
    },
    {
      "type": "timeseries",
      "title": "Среднее время AI-анализа",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 45,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "(sum(rate(lex_ai_analysis_duration_seconds_sum[5m])) / clamp_min(sum(rate(lex_ai_analysis_duration_seconds_count[5m])), 0.000001))",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "id": 17
    },
    {
      "type": "logs",
      "title": "Backend logs",
      "datasource": "Loki",
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 12,
        "h": 12
      },
      "targets": [
        {
          "expr": "{service=~\"backend|lex-backend|backend-1|lexanalytica-backend\", container=~\".*backend.*\"}"
        }
      ],
      "id": 18
    },
    {
      "type": "logs",
      "title": "Только ERROR / Exception",
      "datasource": "Loki",
      "gridPos": {
        "x": 12,
        "y": 50,
        "w": 12,
        "h": 12
      },
      "targets": [
        {
          "expr": "{service=~\"backend|lex-backend|backend-1|lexanalytica-backend\", container=~\".*backend.*\"} |= \"ERROR\" or {service=~\"backend|lex-backend|backend-1|lexanalytica-backend\", container=~\".*backend.*\"} |= \"Exception\""
        }
      ],
      "id": 19
    }
  ]
}