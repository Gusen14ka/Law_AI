{
  "title": "Executive / Business Overview",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Статус системы",
      "targets": [
        {"expr": "up{job='lex-backend'}"}
      ]
    },
    {
      "type": "stat",
      "title": "Заявок за сегодня",
      "targets": [
        {
          "expr": "increase(http_requests_total{job='lex-backend', path='/api/requests', method='POST'}[24h])"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Успешность (%)",
      "targets": [
        {
          "expr": "(1 - rate(http_requests_total{job='lex-backend',status=~'5..'}[1h]) / rate(http_requests_total{job='lex-backend'}[1h])) * 100"
        }
      ]
    }
  ]
}