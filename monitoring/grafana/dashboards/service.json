{
  "title": "Service Overview",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "timeseries",
      "title": "RPS",
      "targets": [
        {"expr": "rate(http_requests_total{job='lex-backend'}[1m])"}
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "targets": [
        {"expr": "rate(http_requests_total{status=~'2..'}[1m])", "legendFormat": "2xx"},
        {"expr": "rate(http_requests_total{status=~'4..'}[1m])", "legendFormat": "4xx"},
        {"expr": "rate(http_requests_total{status=~'5..'}[1m])", "legendFormat": "5xx"}
      ]
    }
  ]
}